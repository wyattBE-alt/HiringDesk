# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Applicant side (JSearch via RapidAPI) ─────────────────────────────────────
JSEARCH_API_KEY=your_rapidapi_key_here

# ── Email notifications (optional — recruiter side) ───────────────────────────
# If not set, recruiter reports show as downloadable HTML preview instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=HiringDesk <your_email@gmail.com>

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
