{
  "name": "hiringdesk",
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered resume matching and candidate ranking platform",
  "author": "HiringDesk",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --env-file=.env --watch server.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "express-rate-limit": "^8.5.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "pdfjs-dist": "^6.0.227"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.hiringdesk.app",
    "productName": "HiringDesk",
    "copyright": "Copyright © 2025 HiringDesk",
    "files": [
      "**/*",
      "!.env",
      "!hiringdesk.db",
      "!hiringdesk.db-shm",
      "!hiringdesk.db-wal",
      "!SESSION_CONTEXT.md",
      "!dist/**"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "buildDependenciesFromSource": true,
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
